# Blink AI Gateway (preferred when set — OpenAI-compatible, 200+ models)
BLINK_API_KEY=blnk_ak_...
# BLINK_MODEL=xai/grok-4.1-fast-non-reasoning
# BLINK_VISION_MODEL=google/gemini-2.5-flash

# OpenAI (default provider when no Blink/Grok key)
OPENAI_API_KEY=sk-...

# Grok / xAI (direct xAI API — used when GROK_API_KEY or XAI_API_KEY is set)
GROK_API_KEY=xai-...
# XAI_API_KEY=xai-...

# Renaiss integrations (live by default)
RENAISS_USE_LIVE=true
# RENAISS_MARKETPLACE_API=https://www.renaiss.xyz/api/trpc/collectible.list
# RENAISS_SCANNER_API=https://renaiss-tool-689931.napa.de5.net

# Optional: Supabase (future persistence)
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=